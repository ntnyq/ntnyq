{
  "name": "ntnyq",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "check": "run-s format:check lint typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "husky",
    "start": "tsx scripts/index.ts",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "consola": "^3.4.2",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "ofetch": "^1.5.1",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "picocolors": "^1.1.1",
    "tsx": "^4.23.1"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@11.15.1"
}
