{
  "oxc.enable": true,
  "eslint.enable": false,
  "prettier.enable": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "js/ts.experimental.useTsgo": true,
  "cSpell.allowCompoundWords": true,
  "cSpell.words": [
    "Bilibili",
    "esbuild",
    "esno",
    "Juejin",
    "Nuxt",
    "ofetch",
    "ohmyfetch",
    "oxfmt",
    "oxlint",
    "pnpm",
    "tsgo",
    "unrs"
  ]
}
